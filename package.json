{
  "name": "quickdropx-automation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test":            "playwright test",
    "test:login":      "playwright test tests/smoke/login.spec.js --headed",
    "test:signup":     "playwright test tests/smoke/signup.spec.js --headed",
    "test:add-draft":  "playwright test tests/smoke/Add-Draft.spec.js --headed",
    "test:publish":    "playwright test tests/smoke/publish-product.spec.js --headed",
    "test:smoke":      "playwright test tests/smoke/ --headed",
    "test:ci":         "playwright test",
    "test:debug":      "playwright test --debug",
    "report":          "playwright show-report"
  },
  "dependencies": {
    "@playwright/test": "^1.57.0"
  }
}
